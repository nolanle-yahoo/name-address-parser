# Which external address validation provider to use.
# Options: mock | usps | smarty
ADDRESS_VALIDATOR=mock

# --- USPS Web Tools (https://www.usps.com/business/web-tools-apis/) ---
# Register to get a USERID. The free Address Validation API (Address Standardization)
# is used to confirm an address is mailable in the US.
USPS_USER_ID=

# --- Smarty / SmartyStreets US Street API (https://www.smarty.com/) ---
# Create an account and a key pair (auth-id / auth-token) for the US Street Address API.
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=
# Use "us-core-cloud" license for production keys, or leave blank for the default.
SMARTY_LICENSE=

# CORS: comma-separated list of origins allowed to call the API (web + mobile dev servers)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8081,http://localhost:19006
